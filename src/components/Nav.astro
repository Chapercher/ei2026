---
const links = [
  { href: '#hero', label: 'Intro' },
  { href: '#hub', label: 'Pôles & outils' },
  { href: '#client-focus', label: 'Client phare' },
  { href: '#bilan', label: 'Bilan' },
];
---
<nav class="nav">
  <div class="nav-inner">
    <a href="#hero" class="brand">
      <span class="brand-dot"></span>
      <span>EI · 2026</span>
    </a>
    <ul>
      {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: calc(100% - 32px);
    max-width: 1000px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(24px) saturate(1.3);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    border: 1px solid var(--border);
    border-radius: 999px;
    box-shadow: 0 10px 30px -10px rgba(58, 70, 120, 0.2);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-0);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .brand-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mint-deep);
    box-shadow: 0 0 12px var(--mint-deep);
  }

  .nav ul {
    display: flex;
    gap: 4px;
    list-style: none;
  }

  .nav ul a {
    display: block;
    padding: 6px 12px;
    color: var(--text-2);
    font-size: 0.85rem;
    border-radius: 999px;
    transition: all 0.2s;
  }

  .nav ul a:hover {
    color: var(--text-0);
    background: var(--surface);
  }

  @media (max-width: 720px) {
    .nav ul { display: none; }
  }
</style>
