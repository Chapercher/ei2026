---
<section id="hub" class="hub-section">
  <div class="container">
    <div class="section-head reveal">
      <span class="tag tag-accent">L'humain au cœur</span>
      <h2>Au centre des <span class="gradient-text">pôles de l'agence</span></h2>
      <p>Cliquez sur un pôle pour voir les outils et projets que j'ai conçus pour eux cette année.</p>
    </div>

    <div class="hub reveal">
      <div class="hub-map">
        <div class="me">
          <div class="me-inner">
            <span>Quentin</span>
            <small>Pôle IA</small>
          </div>
        </div>
        {poles.map((p, i) => (
          <button
            type="button"
            class={`pole pole-${i} pole-${p.color}`}
            data-pole={p.id}
            aria-label={`Voir les projets pour ${p.name}`}
          >
            <span class="pole-icon">{p.icon}</span>
            <span class="pole-name">{p.name}</span>
          </button>
        ))}
        <svg class="connections" viewBox="0 0 600 600" preserveAspectRatio="none" aria-hidden="true">
          <line x1="300" y1="300" x2="80" y2="160" />
          <line x1="300" y1="300" x2="520" y2="160" />
          <line x1="300" y1="300" x2="60" y2="440" />
          <line x1="300" y1="300" x2="540" y2="440" />
          <line x1="300" y1="300" x2="300" y2="560" />
        </svg>
      </div>

      <div class="hub-panel" id="hub-panel">
        {poles.map((p, i) => (
          <article class={`panel-content ${i === 0 ? 'is-active' : ''}`} data-panel={p.id}>
            <header class={`panel-head panel-${p.color}`}>
              <div>
                <span class="panel-icon">{p.icon}</span>
                <h3>{p.name}</h3>
              </div>
              <p>{p.desc}</p>
            </header>
            <div class="slider-wrap">
              <button class="slider-btn slider-prev" type="button" aria-label="Précédent" data-dir="-1">‹</button>
              <div class="slider" data-slider>
                {p.tools.map((t) => (
                  <article class={`tool tool-${t.status || 'default'}`}>
                    {t.image && (
                      <a class="tool-image" href={t.image} target="_blank" rel="noopener" aria-label="Voir en grand">
                        <img src={t.image} alt={t.name} loading="lazy" />
                      </a>
                    )}
                    <div class="tool-body">
                      <header class="tool-head">
                        <h4>{t.name}</h4>
                        {t.status && t.status !== 'placeholder' && (
                          <span class={`tool-status status-${t.status}`}>
                            {t.status === 'prod' && '● En prod'}
                            {t.status === 'dev' && '● En dev'}
                            {t.status === 'obsolete' && '◌ Obsolète'}
                          </span>
                        )}
                      </header>
                      <p>{t.summary}</p>
                      {t.impact && <div class="tool-impact"><strong>Impact :</strong> {t.impact}</div>}
                      <div class="tool-tech">
                        {t.tech.map((c) => <span class="chip">{c}</span>)}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
              <button class="slider-btn slider-next" type="button" aria-label="Suivant" data-dir="1">›</button>
              <div class="slider-dots" data-dots data-count={p.tools.length}></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // --- Navigation pôles ---
    const buttons = document.querySelectorAll('.pole[data-pole]');
    const panels = document.querySelectorAll('.panel-content');
    if (buttons[0]) buttons[0].classList.add('is-active');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-pole');
        buttons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        panels.forEach((p) => {
          p.classList.toggle('is-active', p.getAttribute('data-panel') === id);
        });
        const panel = document.getElementById('hub-panel');
        if (panel) panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });

    // --- Sliders d'outils ---
    document.querySelectorAll('.slider-wrap').forEach((wrap) => {
      const slider = wrap.querySelector('[data-slider]');
      const prev = wrap.querySelector('.slider-prev');
      const next = wrap.querySelector('.slider-next');
      const dotsContainer = wrap.querySelector('[data-dots]');
      const count = parseInt(dotsContainer?.dataset.count || '0', 10);

      // Génération des dots
      if (dotsContainer && count > 1) {
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.setAttribute('aria-label', `Aller à l'outil ${i + 1}`);
          if (i === 0) dot.classList.add('is-active');
          dot.addEventListener('click', () => {
            const card = slider.children[i];
            if (card) card.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
          });
          dotsContainer.appendChild(dot);
        }
      }

      // Boutons prev/next
      const scrollByCard = (dir) => {
        const card = slider.querySelector('.tool');
        if (!card) return;
        const w = card.getBoundingClientRect().width + 18;
        slider.scrollBy({ left: w * dir, behavior: 'smooth' });
      };
      prev?.addEventListener('click', () => scrollByCard(-1));
      next?.addEventListener('click', () => scrollByCard(1));

      // Cacher boutons si un seul outil
      if (count <= 1) {
        prev?.style.setProperty('display', 'none');
        next?.style.setProperty('display', 'none');
      }

      // Mise à jour dots sur scroll
      const dots = dotsContainer?.querySelectorAll('button');
      if (dots && dots.length > 0) {
        slider.addEventListener('scroll', () => {
          const idx = Math.round(slider.scrollLeft / slider.clientWidth);
          dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
        });
      }

      // Cacher prev/next en bord
      const updateArrows = () => {
        if (!prev || !next) return;
        const max = slider.scrollWidth - slider.clientWidth - 2;
        prev.style.opacity = slider.scrollLeft <= 2 ? '0.3' : '1';
        next.style.opacity = slider.scrollLeft >= max ? '0.3' : '1';
        prev.style.pointerEvents = slider.scrollLeft <= 2 ? 'none' : 'auto';
        next.style.pointerEvents = slider.scrollLeft >= max ? 'none' : 'auto';
      };
      updateArrows();
      slider.addEventListener('scroll', updateArrows);
    });
  });
</script>

<style>
  .hub {
    display: grid;
    grid-template-columns: 460px minmax(0, 1fr);
    gap: 56px;
    align-items: start;
  }

  @media (max-width: 1100px) {
    .hub { grid-template-columns: 380px minmax(0, 1fr); gap: 40px; }
  }

  @media (max-width: 960px) {
    .hub { grid-template-columns: 1fr; gap: 40px; }
  }

  .hub-map {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    max-width: 460px;
    margin: 0 auto;
  }

  .connections {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .connections line {
    stroke: rgba(157, 127, 209, 0.35);
    stroke-width: 1.2;
    stroke-dasharray: 4 6;
    animation: dash 14s linear infinite;
  }

  @keyframes dash { to { stroke-dashoffset: -100; } }

  .me {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .me-inner {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--lavender-deep), var(--mint-deep) 55%, var(--rose-deep));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: white;
    font-family: var(--font-display);
    box-shadow: 0 0 60px rgba(201, 184, 232, 0.6);
    animation: pulse-glow 3.5s infinite;
  }

  .me-inner span {
    font-size: 1.25rem;
    font-weight: 700;
  }
  .me-inner small {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.9;
    margin-top: 4px;
  }

  .pole {
    position: absolute;
    width: 150px;
    padding: 16px 14px;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    border-radius: 16px;
    backdrop-filter: blur(20px);
    text-align: center;
    cursor: pointer;
    z-index: 1;
    transition: all 0.3s;
    box-shadow: var(--shadow-soft);
    font-family: var(--font-display);
    color: var(--text-0);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .pole:hover {
    transform: scale(1.06);
    box-shadow: 0 20px 50px -15px rgba(58, 70, 120, 0.2);
  }

  .pole.is-active {
    transform: scale(1.06);
    border-width: 2px;
  }

  .pole-0 { top: 18%; left: 0; }
  .pole-1 { top: 18%; right: 0; }
  .pole-2 { bottom: 18%; left: 0; }
  .pole-3 { bottom: 18%; right: 0; }
  .pole-4 { bottom: -2%; left: 50%; transform: translateX(-50%); }
  .pole-4:hover, .pole-4.is-active { transform: translateX(-50%) scale(1.06); }

  .pole-mint.is-active { border-color: var(--mint-deep); background: rgba(158, 213, 197, 0.35); }
  .pole-rose.is-active { border-color: var(--rose-deep); background: rgba(243, 183, 199, 0.35); }
  .pole-lavender.is-active { border-color: var(--lavender-deep); background: rgba(201, 184, 232, 0.4); }
  .pole-sky.is-active { border-color: var(--sky-deep); background: rgba(184, 204, 228, 0.4); }
  .pole-gold.is-active { border-color: var(--butter-deep); background: rgba(245, 230, 168, 0.5); }

  .pole-icon { font-size: 1.6rem; }
  .pole-name { font-size: 0.92rem; font-weight: 600; }

  /* Panel */
  .hub-panel {
    position: relative;
    min-height: 400px;
  }

  .panel-content {
    display: none;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
  }

  .panel-content.is-active {
    display: block;
  }

  .panel-head {
    padding: 28px;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: 24px;
    backdrop-filter: blur(20px);
    box-shadow: var(--shadow-soft);
  }

  .panel-head > div {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
  }

  .panel-icon {
    font-size: 2rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.6);
  }

  .panel-mint { border-left: 4px solid var(--mint-deep); }
  .panel-rose { border-left: 4px solid var(--rose-deep); }
  .panel-lavender { border-left: 4px solid var(--lavender-deep); }
  .panel-sky { border-left: 4px solid var(--sky-deep); }
  .panel-gold { border-left: 4px solid var(--butter-deep); }

  .panel-head h3 {
    font-size: 1.5rem;
    margin: 0;
  }

  .panel-head p {
    color: var(--text-2);
    margin: 0;
  }

  .slider-wrap {
    position: relative;
  }

  .slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 18px;
    padding: 6px 4px 14px;
    scrollbar-width: thin;
    scrollbar-color: var(--lavender-deep) transparent;
  }

  .slider::-webkit-scrollbar { height: 6px; }
  .slider::-webkit-scrollbar-track { background: transparent; }
  .slider::-webkit-scrollbar-thumb {
    background: rgba(157, 127, 209, 0.4);
    border-radius: 6px;
  }

  .tool {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: grid;
    grid-template-columns: 1fr;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(16px);
    transition: all 0.3s;
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .tool:has(.tool-image) {
    grid-template-columns: 240px 1fr;
  }

  @media (max-width: 720px) {
    .tool:has(.tool-image) {
      grid-template-columns: 1fr;
    }
  }

  /* Boutons slider */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    color: var(--lavender-deep);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    z-index: 5;
    box-shadow: 0 6px 20px -6px rgba(58, 70, 120, 0.25);
    backdrop-filter: blur(10px);
    transition: all 0.25s;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 4px;
  }

  .slider-btn:hover {
    background: white;
    transform: translateY(-50%) scale(1.1);
    color: var(--mint-deep);
  }

  .slider-prev { left: -18px; }
  .slider-next { right: -18px; }

  @media (max-width: 720px) {
    .slider-prev { left: 4px; }
    .slider-next { right: 4px; }
  }

  /* Dots */
  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 14px;
  }

  .slider-dots button {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(157, 127, 209, 0.25);
    cursor: pointer;
    padding: 0;
    transition: all 0.25s;
  }

  .slider-dots button.is-active {
    background: var(--lavender-deep);
    transform: scale(1.4);
  }

  .tool-placeholder {
    border-style: dashed;
    opacity: 0.6;
  }

  .tool:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: 0 18px 40px -15px rgba(58, 70, 120, 0.18);
  }

  .tool-image {
    position: relative;
    display: block;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(201,184,232,0.2), rgba(158,213,197,0.2));
    border-right: 1px solid var(--border);
  }

  .tool-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
