---
const quests = [
  // À remplir ensemble via les questions d'entretien.
  // Format : { code, title, type, summary, results, tech, status }
  {
    code: 'Q-001',
    title: '[Mission à définir]',
    type: 'En attente',
    summary: 'Cette quête sera décrite lors de notre session questions/réponses.',
    results: ['—'],
    tech: ['?'],
    status: 'placeholder',
  },
];
---
<section id="quetes" class="quests">
  <div class="container">
    <div class="section-head reveal">
      <span class="tag tag-accent">◇ Chapitre 1</span>
      <h2>Carte des <span class="gradient-text">quêtes accomplies</span></h2>
      <p>Les missions et projets menés cette année — chacun avec ses objectifs, ses livrables et l'impact pour l'agence et nos clients.</p>
    </div>

    <div class="quest-grid">
      {quests.map((q) => (
        <article class={`quest reveal ${q.status === 'placeholder' ? 'is-placeholder' : ''}`}>
          <header class="quest-head">
            <span class="quest-code">{q.code}</span>
            <span class="tag">{q.type}</span>
          </header>
          <h3 class="quest-title">{q.title}</h3>
          <p class="quest-summary">{q.summary}</p>
          <div class="quest-results">
            <h4>Résultats</h4>
            <ul>
              {q.results.map((r) => <li>{r}</li>)}
            </ul>
          </div>
          <div class="quest-tech">
            {q.tech.map((t) => <span class="chip">{t}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .quest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .quest {
    padding: 28px;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(20px);
    transition: all 0.35s;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .quest::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--mint), var(--rose), var(--sky), var(--butter), var(--lavender));
    opacity: 0;
    transition: opacity 0.35s;
  }

  .quest:hover {
    transform: translateY(-5px);
    border-color: rgba(157, 127, 209, 0.4);
    box-shadow: 0 20px 50px -15px rgba(58, 70, 120, 0.18);
  }

  .quest:hover::before { opacity: 1; }

  .quest.is-placeholder {
    border-style: dashed;
    opacity: 0.6;
  }

  .quest-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .quest-code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--mint-deep);
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .quest-title {
    margin-bottom: 12px;
  }

  .quest-summary {
    color: var(--text-1);
    font-size: 0.95rem;
    margin-bottom: 20px;
  }

  .quest-results h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    margin-bottom: 8px;
  }

  .quest-results ul {
    list-style: none;
    margin-bottom: 20px;
  }

  .quest-results li {
    position: relative;
    padding-left: 18px;
    color: var(--text-1);
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .quest-results li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--lavender-deep);
  }

  .quest-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .chip {
    padding: 4px 10px;
    border-radius: 6px;
    background: rgba(158, 213, 197, 0.3);
    border: 1px solid rgba(107, 185, 163, 0.35);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--mint-deep);
  }
</style>
