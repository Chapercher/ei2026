---
const poles = [
  { name: 'Webmarketing', icon: '📈', desc: 'Coordination des campagnes, intégrations, suivi technique' },
  { name: 'Graphistes', icon: '🎨', desc: 'Pont entre maquettes et intégration, conseil technique' },
  { name: 'Développeurs', icon: '⚙️', desc: 'Mon pôle d\'attache — code, archi, revue' },
  { name: 'Compta', icon: '📊', desc: 'Support sur les outils, automatisation, IA' },
];
---
<section id="equipe" class="team">
  <div class="container">
    <div class="section-head reveal">
      <span class="tag tag-accent">◈ Chapitre 4</span>
      <h2>Au centre de <span class="gradient-text">l'équipe</span></h2>
      <p>Je gravite entre les pôles. C'est rarement écrit dans la fiche de poste, mais c'est ce qui fait avancer les projets.</p>
    </div>

    <div class="team-map reveal">
      <div class="me">
        <div class="me-inner">
          <span>Moi</span>
        </div>
      </div>
      {poles.map((p, i) => (
        <div class={`pole pole-${i}`}>
          <div class="pole-icon">{p.icon}</div>
          <h3>{p.name}</h3>
          <p>{p.desc}</p>
        </div>
      ))}
      <svg class="connections" viewBox="0 0 600 600" preserveAspectRatio="none" aria-hidden="true">
        <line x1="300" y1="300" x2="100" y2="100" />
        <line x1="300" y1="300" x2="500" y2="100" />
        <line x1="300" y1="300" x2="100" y2="500" />
        <line x1="300" y1="300" x2="500" y2="500" />
      </svg>
    </div>
  </div>
</section>

<style>
  .team-map {
    position: relative;
    width: 100%;
    max-width: 720px;
    aspect-ratio: 1;
    margin: 0 auto;
  }

  .connections {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .connections line {
    stroke: rgba(157, 127, 209, 0.35);
    stroke-width: 1.2;
    stroke-dasharray: 4 6;
    animation: dash 12s linear infinite;
  }

  @keyframes dash {
    to { stroke-dashoffset: -100; }
  }

  .me {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .me-inner {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--lavender-deep), var(--mint-deep) 60%, var(--rose-deep));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: 1.3rem;
    box-shadow: 0 0 60px rgba(201, 184, 232, 0.6);
    animation: pulse-glow 3s infinite;
  }

  .pole {
    position: absolute;
    width: 200px;
    padding: 18px;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(20px);
    text-align: center;
    z-index: 1;
    transition: all 0.3s;
    box-shadow: var(--shadow-soft);
  }

  .pole:hover {
    transform: scale(1.05);
    border-color: var(--lavender-deep);
  }

  .pole-0 { top: 0; left: 0; }
  .pole-1 { top: 0; right: 0; }
  .pole-2 { bottom: 0; left: 0; }
  .pole-3 { bottom: 0; right: 0; }

  .pole-icon { font-size: 2rem; margin-bottom: 6px; }

  .pole h3 { font-size: 1rem; margin-bottom: 4px; }
  .pole p { font-size: 0.8rem; color: var(--text-2); }

  @media (max-width: 720px) {
    .team-map {
      aspect-ratio: auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .me { position: relative; top: auto; left: auto; transform: none; grid-column: 1 / -1; justify-self: center; }
    .me-inner { width: 110px; height: 110px; font-size: 1.1rem; }
    .pole { position: relative; width: 100%; top: auto; left: auto; right: auto; bottom: auto; }
    .connections { display: none; }
  }
</style>
